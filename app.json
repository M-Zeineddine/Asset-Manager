{
  "expo": {
    "name": "LocalTreats",
    "slug": "local-treats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "localtreats",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.localtreats",
      "buildNumber": "1",
      "appleTeamId": "346JF2CT6X",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.localtreats",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://asset-manager-zu1v.onrender.com"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "publicDomain": "asset-manager-zu1v.onrender.com",
      "router": {
        "origin": "https://asset-manager-zu1v.onrender.com"
      },
      "eas": {
        "projectId": "10b010e0-6460-45eb-be36-03390da9f598"
      }
    }
  }
}
